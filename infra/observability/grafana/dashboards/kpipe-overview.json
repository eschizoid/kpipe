        {
          "expr": "sum by (pipeline) (rate(kpipe_consumer_messages_received_total[30s]))",
          "legendFormat": "{{pipeline}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
