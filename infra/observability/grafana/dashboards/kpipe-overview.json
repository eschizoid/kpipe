        {
          "expr": "sum by (pipeline) (rate(kpipe_consumer_messages_processed_total[30s]))",
          "legendFormat": "{{pipeline}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
